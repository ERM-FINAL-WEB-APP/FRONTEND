# ─── SPA rewrite for Apache hosts (Hostinger / cPanel) ─────────────
# Without this, navigating directly to /dashboard, /manager, /profile,
# etc. returns a 404 because the host looks for files at those paths.
# With it, every non-file URL falls through to /index.html so React
# Router can take over.

RewriteEngine On
RewriteBase /

# If the request is for an existing file (JS, CSS, image, etc.), serve it.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, serve index.html so React Router can resolve the route.
RewriteRule ^ index.html [L]

# Long-cache fingerprinted static assets — Vite hashes filenames so this
# is safe; a code change produces a new filename, busting the cache.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|webp|woff|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# gzip everything text-y (most Apache hosts have mod_deflate on by default)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Security headers — light touch, doesn't break Vercel previews either
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
