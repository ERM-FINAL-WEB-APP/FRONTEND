# Force npm to install platform-specific optional deps (e.g. the Linux
# rollup binary). Vercel runs on Linux x64; Windows-generated lockfiles
# omit @rollup/rollup-linux-x64-gnu by default and the Vite build crashes
# with "Cannot find module @rollup/rollup-linux-x64-gnu". This setting
# eliminates that failure mode.
optional=true
include=optional
fund=false
audit=false
